# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=dbname
POSTGRES_PORT=5432

# Application Configuration
API_PORT=8080
GIN_MODE=release

# Database Connection (used by API)
DB_URL=postgres://postgres:your_secure_password_here@postgres:5432/dbname

# Goose Migration Configuration
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:your_secure_password_here@postgres:5432/blog-go

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_at_least_32_characters
